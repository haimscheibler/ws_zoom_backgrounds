<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ full_name }} — {{ company_name }}</title>
  <style>
    /* Fixed 1920×1080 canvas matching the Playwright viewport — no scaling. */
    html, body {
      margin: 0;
      padding: 0;
      width: 1920px;
      height: 1080px;
      overflow: hidden;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    /* PLATE LAYER — static background scene chosen by the user. The
       background string is injected verbatim from plates.py. Confining the
       full-frame surface to zero motion keeps Zoom's matting algorithm
       happy: only the corner watermark animates. */
    .plate {
      position: absolute;
      inset: 0;
      {{ plate_css|safe }}
    }

    /* WATERMARK OVERLAY — brand mark (top-right) + nametag (bottom-left).
       This is where all motion lives. Both elements share a 10-second loop
       with matched first/last frames for seamless Zoom looping. */

    /* The brand-mark container: round white plate with a brand-colour ring.
       Holds either one image (photo or logo, with a subtle pulse) or both
       (with a slow crossfade). Mode is selected by a class on the container,
       set server-side from brand_mark_mode. */
    .brand-mark {
      position: absolute;
      top: 56px;
      right: 56px;
      width: 140px;
      height: 140px;
      border-radius: 50%;
      background: #fff;
      box-shadow:
        0 0 0 2px {{ brand_color }}55,
        0 10px 30px rgba(0, 0, 0, 0.28);
      overflow: hidden;
      animation: markPulse 10s ease-in-out infinite;
    }
    @keyframes markPulse {
      0%, 100% { transform: scale(0.97); }
      50%      { transform: scale(1.00); }
    }

    .brand-mark .layer {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      display: block;
    }
    /* Photo fills the circle (likely a headshot — cover, not contain).
       Logo gets padding so it doesn't kiss the brand-colour ring; contain
       so wide wordmarks aren't cropped. */
    .brand-mark .layer.photo {
      object-fit: cover;
    }
    .brand-mark .layer.logo {
      object-fit: contain;
      padding: 18%;
      box-sizing: border-box;
    }

    /* Crossfade — only when both layers are present. Timings mirror the
       email-signature animator: ~40% hold each side, ~10% transitions.
       Cubic ease-in-out (CSS default for ease-in-out) matches animator.py's
       _ease_in_out(). Frame 0 and frame 100% both land on full photo, so
       the loop is seamless when ffmpeg trims to a single period. */
    .brand-mark.mode-both .layer.photo {
      animation: fadePhoto 10s ease-in-out infinite;
    }
    .brand-mark.mode-both .layer.logo {
      animation: fadeLogo 10s ease-in-out infinite;
    }
    @keyframes fadePhoto {
      0%, 35%, 100% { opacity: 1; }
      50%, 85%      { opacity: 0; }
    }
    @keyframes fadeLogo {
      0%, 35%, 100% { opacity: 0; }
      50%, 85%      { opacity: 1; }
    }
    /* Single-layer modes: hide the other layer entirely. (`mode-photo` /
       `mode-logo` paths — only one layer ever rendered, but defensive in
       case both fields are accidentally populated.) */
    .brand-mark.mode-photo .layer.logo,
    .brand-mark.mode-logo .layer.photo {
      display: none;
    }

    .nametag {
      position: absolute;
      left: 80px;
      bottom: 88px;
      max-width: 720px;
      padding: 24px 36px 24px 32px;
      /* Translucent dark with backdrop blur — readable against both light
         plates (where the dark wash provides contrast) and dark plates
         (where the blur picks up the plate's tone). */
      background: rgba(10, 22, 38, 0.78);
      backdrop-filter: blur(14px);
      border-left: 6px solid {{ brand_color }};
      border-radius: 12px;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
      color: #fff;
      /* Subtle brightness pulse on the whole tag — reads as a gentle "alive"
         glow rather than a movement, which is exactly what we want around
         someone's silhouette. */
      animation: nametagBreathe 10s ease-in-out infinite;
    }
    @keyframes nametagBreathe {
      0%, 100% { filter: brightness(0.96); }
      50%      { filter: brightness(1.04); }
    }
    .nametag .name {
      font-size: 44px;
      font-weight: 700;
      letter-spacing: -0.5px;
      line-height: 1.1;
      margin: 0;
    }
    .nametag .title {
      font-size: 22px;
      font-weight: 400;
      opacity: 0.85;
      margin: 6px 0 0;
    }
    .nametag .company {
      font-size: 18px;
      font-weight: 600;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin: 14px 0 0;
      padding-top: 12px;
      border-top: 1px solid rgba(255, 255, 255, 0.18);
    }
    .nametag .accent {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: {{ brand_color }};
      margin-right: 10px;
      vertical-align: middle;
      /* Phase-offset opacity pulse — feels like a status dot rather than the
         tag itself moving. Slight glow via box-shadow that scales with
         opacity gives it depth without dimensions changing. */
      animation: accentPulse 10s ease-in-out infinite;
    }
    @keyframes accentPulse {
      0%, 100% { opacity: 0.55; box-shadow: 0 0 0 0 {{ brand_color }}00; }
      50%      { opacity: 1.00; box-shadow: 0 0 12px 2px {{ brand_color }}66; }
    }
  </style>
</head>
<body>
  <div class="plate"></div>

  {% if brand_mark_mode != "none" %}
  <div class="brand-mark mode-{{ brand_mark_mode }}">
    {% if photo_url %}
    <img class="layer photo" src="{{ photo_url }}" alt="{{ full_name }}">
    {% endif %}
    {% if logo_url %}
    <img class="layer logo" src="{{ logo_url }}" alt="{{ company_name }}">
    {% endif %}
  </div>
  {% endif %}

  <div class="nametag">
    <p class="name">{{ full_name }}</p>
    {% if title %}<p class="title">{{ title }}</p>{% endif %}
    <p class="company"><span class="accent"></span>{{ company_name }}</p>
  </div>
</body>
</html>
