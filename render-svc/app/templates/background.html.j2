<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ full_name }} — {{ company_name }}</title>
  <style>
    /* Fixed 1920×1080 canvas matching the Playwright viewport — no scaling. */
    html, body {
      margin: 0;
      padding: 0;
      width: 1920px;
      height: 1080px;
      overflow: hidden;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      -webkit-font-smoothing: antialiased;
    }

    /* PLATE LAYER — static background scene chosen by the user. The
       background string is injected verbatim from plates.py. Confining the
       full-frame surface to zero motion keeps Zoom's matting algorithm
       happy: only the corner watermark animates. */
    .plate {
      position: absolute;
      inset: 0;
      {{ plate_css|safe }}
    }

    /* WATERMARK OVERLAY — brand logo (top-right) + nametag (bottom-left).
       This is where all motion lives. Both elements have small, slow
       animations on a shared 10-second loop with matched first/last
       frames for seamless Zoom looping. */

    .logo-mark {
      position: absolute;
      top: 56px;
      right: 56px;
      width: 140px;
      height: 140px;
      border-radius: 50%;
      background: #fff;
      /* Two-layer shadow: a tight ring of brand color, then a soft drop —
         the ring keeps the white logo plate legible against light plates
         (where a pure drop-shadow alone would fade), and the drop adds
         depth on dark plates. */
      box-shadow:
        0 0 0 2px {{ brand_color }}55,
        0 10px 30px rgba(0, 0, 0, 0.28);
      display: flex;
      align-items: center;
      justify-content: center;
      animation: logoPulse 10s ease-in-out infinite;
    }
    .logo-mark img {
      max-width: 100px;
      max-height: 100px;
      object-fit: contain;
    }
    @keyframes logoPulse {
      0%, 100% { transform: scale(0.97); }
      50%      { transform: scale(1.00); }
    }

    .nametag {
      position: absolute;
      left: 80px;
      bottom: 88px;
      max-width: 720px;
      padding: 24px 36px 24px 32px;
      /* Translucent dark with backdrop blur — readable against both light
         plates (where the dark wash provides contrast) and dark plates
         (where the blur picks up the plate's tone). */
      background: rgba(10, 22, 38, 0.78);
      backdrop-filter: blur(14px);
      border-left: 6px solid {{ brand_color }};
      border-radius: 12px;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.35);
      color: #fff;
      /* Subtle brightness pulse on the whole tag — reads as a gentle "alive"
         glow rather than a movement, which is exactly what we want around
         someone's silhouette. */
      animation: nametagBreathe 10s ease-in-out infinite;
    }
    @keyframes nametagBreathe {
      0%, 100% { filter: brightness(0.96); }
      50%      { filter: brightness(1.04); }
    }
    .nametag .name {
      font-size: 44px;
      font-weight: 700;
      letter-spacing: -0.5px;
      line-height: 1.1;
      margin: 0;
    }
    .nametag .title {
      font-size: 22px;
      font-weight: 400;
      opacity: 0.85;
      margin: 6px 0 0;
    }
    .nametag .company {
      font-size: 18px;
      font-weight: 600;
      letter-spacing: 0.5px;
      text-transform: uppercase;
      margin: 14px 0 0;
      padding-top: 12px;
      border-top: 1px solid rgba(255, 255, 255, 0.18);
    }
    .nametag .accent {
      display: inline-block;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: {{ brand_color }};
      margin-right: 10px;
      vertical-align: middle;
      /* Phase-offset opacity pulse — feels like a status dot rather than the
         tag itself moving. Slight glow via box-shadow that scales with
         opacity gives it depth without dimensions changing. */
      animation: accentPulse 10s ease-in-out infinite;
    }
    @keyframes accentPulse {
      0%, 100% { opacity: 0.55; box-shadow: 0 0 0 0 {{ brand_color }}00; }
      50%      { opacity: 1.00; box-shadow: 0 0 12px 2px {{ brand_color }}66; }
    }
  </style>
</head>
<body>
  <div class="plate"></div>

  {% if logo_url %}
  <div class="logo-mark">
    <img src="{{ logo_url }}" alt="{{ company_name }}">
  </div>
  {% endif %}

  <div class="nametag">
    <p class="name">{{ full_name }}</p>
    {% if title %}<p class="title">{{ title }}</p>{% endif %}
    <p class="company"><span class="accent"></span>{{ company_name }}</p>
  </div>
</body>
</html>
