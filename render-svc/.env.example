# Apollo People-Match key. When set, we enrich (first_name, last_name, domain)
# against Apollo for the person's photo / LinkedIn + the company's logo, brand
# color source, and socials. When unset, we fall back to homepage scraping
# only — and the quality gate (logo OR photo required) will reject many
# requests that Apollo would otherwise have rescued.
#
# Grab the value from sibling `Automated_Email_Signatures/.env`.
APOLLO_API_KEY=

# Optional — public base URL where /output/*.mp4 is served from. Leave blank for
# local dev (responses will return /output/... relative paths the Next.js app
# proxies through).
PUBLIC_BASE_URL=

# Render output directory. Defaults to app/static/output relative to render-svc/.
OUTPUT_DIR=

# Render timing
LOOP_SECONDS=10
VIDEO_FPS=30
